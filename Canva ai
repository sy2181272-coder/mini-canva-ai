import React, { useEffect, useRef, useState } from 'react';
import { fabric } from 'fabric';

const AI_Canva_App = () => {
  const canvasRef = useRef(null);
  const [canvas, setCanvas] = useState(null);
  const [loading, setLoading] = useState(false);
  const fileInputRef = useRef(null);

  // API Configuration (Aapki Key yahan set hai)
  const HF_TOKEN = "hf_8UtvcFe32Fbgcq2pW822NyUf"; 
  const MODEL_URL = "https://api-inference.huggingface.co/models/ByteDance/SDXL-Lightning";

  useEffect(() => {
    const fabricCanvas = new fabric.Canvas('canvas', {
      height: 550,
      width: 750,
      backgroundColor: '#ffffff',
    });
    setCanvas(fabricCanvas);
    return () => fabricCanvas.dispose();
  }, []);

  // 1. Add Text
  const addText = () => {
    const text = new fabric.IText('Naya Text', {
      left: 100,
      top: 100,
      fontFamily: 'Arial',
      fontSize: 30,
      fill: '#333',
    });
    canvas.add(text).setActiveObject(text);
  };

  // 2. Add Local Image (Upload)
  const handleImageUpload = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (f) => {
      fabric.Image.fromURL(f.target.result, (img) => {
        img.scaleToWidth(200);
        canvas.add(img).centerObject(img).setActiveObject(img);
        canvas.renderAll();
      });
    };
    reader.readAsDataURL(file);
    e.target.value = ""; 
  };

  // 3. AI Image Generation (Using your Key)
  const generateAIImage = async () => {
    const promptText = prompt("Aap kya dekhna chahte hain? (English mein likhein)");
    if (!promptText) return;

    setLoading(true);
    try {
      const response = await fetch(MODEL_URL, {
        headers: { 
          Authorization: `Bearer ${HF_TOKEN}`,
          "Content-Type": "application/json" 
        },
        method: "POST",
        body: JSON.stringify({ inputs: promptText }),
      });

      if (!response.ok) {
        throw new Error("API Busy ya Limit khatam. Thodi der baad try karein.");
      }

      const blob = await response.blob();
      const imageUrl = URL.createObjectURL(blob);

      fabric.Image.fromURL(imageUrl, (img) => {
        img.scaleToWidth(400);
        canvas.add(img).centerObject(img).setActiveObject(img);
        canvas.renderAll();
        setLoading(false);
      });
    } catch (error) {
      console.error("AI Error:", error);
      alert(error.message);
      setLoading(false);
    }
  };

  // 4. Download
  const downloadPNG = () => {
    const dataURL = canvas.toDataURL({ format: 'png', quality: 1 });
    const link = document.createElement('a');
    link.href = dataURL;
    link.download = 'ai-design.png';
    link.click();
  };

  return (
    <div style={styles.app}>
      <div style={styles.topBar}>
        <h2 style={{ margin: 0, fontSize: '20px' }}>⚡ AI Designer</h2>
        <button onClick={downloadPNG} style={styles.downBtn}>Download PNG</button>
      </div>

      <div style={styles.main}>
        <div style={styles.sidebar}>
          <button style={styles.toolBtn} onClick={addText}>Add Text</button>
          
          <input type="file" ref={fileInputRef} onChange={handleImageUpload} hidden accept="image/*" />
          <button style={styles.toolBtn} onClick={() => fileInputRef.current.click()}>Upload Image</button>

          <button 
            style={{ ...styles.toolBtn, background: '#7d2ae8', color: '#fff' }} 
            onClick={generateAIImage}
            disabled={loading}
          >
            {loading ? 'Thinking...' : 'AI Magic'}
          </button>

          <button style={{ ...styles.toolBtn, color: 'red', marginTop: 'auto' }} 
            onClick={() => canvas.remove(canvas.getActiveObject())}>
            Delete
          </button>
        </div>

        <div style={styles.canvasArea}>
          <div style={styles.canvasShadow}>
            <canvas id="canvas" />
          </div>
        </div>
      </div>
    </div>
  );
};

const styles = {
  app: { display: 'flex', flexDirection: 'column', height: '100vh', fontFamily: 'sans-serif' },
  topBar: { display: 'flex', justifyContent: 'space-between', padding: '10px 20px', background: '#fff', borderBottom: '1px solid #ddd', alignItems: 'center' },
  main: { display: 'flex', flex: 1, background: '#f0f2f5' },
  sidebar: { width: '130px', background: '#fff', padding: '20px 10px', display: 'flex', flexDirection: 'column', gap: '15px', borderRight: '1px solid #ddd' },
  toolBtn: { padding: '10px', borderRadius: '6px', border: '1px solid #ddd', cursor: 'pointer', fontSize: '12px', fontWeight: 'bold', background: '#f9f9f9' },
  canvasArea: { flex: 1, display: 'flex', justifyContent: 'center', alignItems: 'center' },
  canvasShadow: { boxShadow: '0 10px 30px rgba(0,0,0,0.1)', background: '#fff' },
  downBtn: { background: '#00c4cc', color: '#fff', border: 'none', padding: '8px 15px', borderRadius: '5px', cursor: 'pointer', fontWeight: 'bold' }
};

export default AI_Canva_App;

