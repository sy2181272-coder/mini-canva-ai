<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Design Studio - Mobile</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
    <style>
        body { font-family: sans-serif; margin: 0; background: #f0f2f5; display: flex; flex-direction: column; height: 100vh; }
        header { background: #fff; padding: 15px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ddd; }
        .main-container { display: flex; flex: 1; overflow: hidden; }
        /* Sidebar for Mobile */
        .sidebar { width: 80px; background: #fff; border-right: 1px solid #ddd; display: flex; flex-direction: column; gap: 10px; padding: 10px; }
        .canvas-area { flex: 1; display: flex; justify-content: center; align-items: center; padding: 10px; overflow: auto; }
        canvas { border: 1px solid #ccc; box-shadow: 0 5px 15px rgba(0,0,0,0.1); background: #fff; }
        button, label { background: #f8f9fa; border: 1px solid #ddd; padding: 8px; font-size: 11px; cursor: pointer; border-radius: 5px; text-align: center; font-weight: bold; }
        .ai-btn { background: #7d2ae8; color: white; border: none; }
        .download-btn { background: #00c4cc; color: white; border: none; padding: 10px 20px; }
        #loader { display: none; color: #7d2ae8; font-size: 10px; font-weight: bold; }
    </style>
</head>
<body>

<header>
    <h3 style="margin:0; font-size: 16px;">⚡ AI Canva</h3>
    <button class="download-btn" onclick="downloadImage()">Download</button>
</header>

<div class="main-container">
    <div class="sidebar">
        <button onclick="addText()">Text</button>
        <label for="imgInput">Upload</label>
        <input type="file" id="imgInput" hidden onchange="uploadImage(event)">
        <button class="ai-btn" onclick="generateAI()">AI Magic</button>
        <span id="loader">Processing...</span>
        <button style="color:red; margin-top: auto;" onclick="deleteObj()">Delete</button>
    </div>

    <div class="canvas-area">
        <canvas id="c"></canvas>
    </div>
</div>

<script>
    // 1. Initialize Canvas
    const canvas = new fabric.Canvas('c');
    
    // Mobile-friendly canvas size
    function resizeCanvas() {
        const width = window.innerWidth - 110;
        const height = window.innerHeight - 100;
        canvas.setDimensions({ width: width, height: height });
    }
    window.onresize = resizeCanvas;
    resizeCanvas();

    // 2. Add Text
    function addText() {
        const text = new fabric.IText('Edit Me', { left: 50, top: 50, fontSize: 25 });
        canvas.add(text).setActiveObject(text);
    }

    // 3. Upload Local Image
    function uploadImage(e) {
        const reader = new FileReader();
        reader.onload = function(event) {
            fabric.Image.fromURL(event.target.result, function(img) {
                img.scaleToWidth(150);
                canvas.add(img).centerObject(img).setActiveObject(img);
            });
        }
        reader.readAsDataURL(e.target.files[0]);
    }

    // 4. AI Generation (ByteDance SDXL-Lightning)
    async function generateAI() {
        const prompt = window.prompt("Enter Prompt (English):", "A neon cat in space");
        if (!prompt) return;

        const loader = document.getElementById('loader');
        loader.style.display = 'block';

        try {
            const response = await fetch(
                "https://api-inference.huggingface.co/models/ByteDance/SDXL-Lightning",
                {
                    headers: { "Authorization": "Bearer hf_8UtvcFe32Fbgcq2pW822NyUf" },
                    method: "POST",
                    body: JSON.stringify({ inputs: prompt }),
                }
            );

            if (!response.ok) throw new Error("API Busy");

            const blob = await response.blob();
            const url = URL.createObjectURL(blob);

            fabric.Image.fromURL(url, function(img) {
                img.scaleToWidth(200);
                canvas.add(img).centerObject(img);
                loader.style.display = 'none';
            });
        } catch (err) {
            alert("Error: " + err.message);
            loader.style.display = 'none';
        }
    }

    // 5. Delete & Download
    function deleteObj() {
        canvas.remove(canvas.getActiveObject());
    }

    function downloadImage() {
        const link = document.createElement('a');
        link.download = 'design.png';
        link.href = canvas.toDataURL({ format: 'png' });
        link.click();
    }
</script>

</body>
</html>
